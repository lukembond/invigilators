<header 
  id="nav" 
  class="sticky top-0 z-50 bg-white/5 backdrop-blur-md py-4 transition-opacity duration-300"
  style="position: sticky; top: 0;"
>
  <div class="container mx-auto px-4 flex items-center justify-between">
    <h1 class="text-2xl md:text-3xl font-bold text-white">
      <a href="/" class="logo-text transition-colors">
        <span class="text-base md:text-sm">the</span> Invigilators
      </a>
    </h1>
    <div class="flex items-center gap-1">
      <button id="nav-up" class="nav-btn text-white/70 hover:text-white px-2 py-1 rounded border border-white/20 bg-white/5 transition-all" aria-label="Previous episode">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" />
        </svg>
      </button>
      <button id="nav-down" class="nav-btn text-white/70 hover:text-white px-2 py-1 rounded border border-white/20 bg-white/5 transition-all" aria-label="Next episode">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </button>
    </div>
  </div>
</header>
