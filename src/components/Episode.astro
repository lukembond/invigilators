---
interface Track {
  n: number;
  artist: string;
  title: string;
  label: string;
}

interface Props {
  id: string;
  title: string;
  date: string;
  location: string;
  length: string;
  mixcloud: string;
  hearthis?: string;
  image: string;
  description: string;
  tracks: Track[];
  index: number;
}

const { id, title, date, location, length, mixcloud, hearthis, image, description, tracks, index } =
  Astro.props;
---

<article
  class="episode relative min-h-screen flex flex-col justify-center bg-cover bg-center"
  data-id={id}
  style={`background-image: url('${image}');`}
>
  <div class="absolute inset-0 bg-black/30 backdrop-blur-sm"></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto py-12">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 items-center justify-items-center">
      <!-- Left: Main content -->
      <div class="bg-black/20 backdrop-blur-md rounded-lg p-6 md:p-8 border border-white/10">
        <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
          <div>
            <h2 class="text-3xl md:text-4xl font-bold text-white mb-2">{title}</h2>
            <p class="text-gray-400">{date} • {location}</p>
          </div>
          <div class="text-right">
            <p class="text-gray-400 text-sm">Length</p>
            <p class="text-white text-xl">{length}</p>
          </div>
        </div>

        <p class="text-gray-300 mb-6">{description}</p>

        {
          (mixcloud || hearthis) && (
            <div
              class="mb-6 w-full h-[60px] mixcloud-container"
              data-mixcloud={mixcloud}
              data-title={title}
            >
              <div class="w-full h-full bg-gray-900/50 border border-white/10 rounded flex items-center justify-center text-gray-400 text-sm gap-2">
                <svg
                  class="animate-spin h-4 w-4"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <circle
                    class="opacity-25"
                    cx="12"
                    cy="12"
                    r="10"
                    stroke="currentColor"
                    stroke-width="4"
                  />
                  <path
                    class="opacity-75"
                    fill="currentColor"
                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                  />
                </svg>
                <span>Loading player...</span>
              </div>
            </div>
          )
        }
      </div>

      <!-- Right: Tracklist -->
      <div class="bg-black/20 backdrop-blur-md rounded-lg p-4 border border-white/10">
        <h3 class="text-lg text-white mb-3">Tracklist</h3>
        <ul class="space-y-1">
          {
            tracks.map((track) => (
              <li class="text-gray-400 text-xs leading-tight border-b border-white/5 pb-1 last:border-0">
                <span class="text-red-900 font-mono mr-1">#{String(track.n).padStart(2, "0")}</span>
                <span class="text-gray-300">{track.artist}</span>
                <span class="text-gray-600 mx-1">—</span>
                <span class="text-gray-400">{track.title}</span>
                {track.label && <span class="text-gray-600 ml-1">[{track.label}]</span>}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</article>
