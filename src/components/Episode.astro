---
interface Track {
  n: number;
  artist: string;
  title: string;
  label: string;
}

interface Props {
  id: string;
  title: string;
  date: string;
  location: string;
  length: string;
  mixcloud: string;
  hearthis?: string;
  image: string;
  description: string;
  tracks: Track[];
  index: number;
}

const { id, title, date, location, length, mixcloud, hearthis, image, description, tracks, index } =
  Astro.props;
const parallaxRatio = 0.5;
---

<article
  class="episode relative min-h-screen flex items-center justify-center parallax"
  data-id={id}
  data-parallax-ratio={parallaxRatio}
  style={`background-image: url('${image}');`}
>
  <div class="absolute inset-0 bg-black/30 backdrop-blur-sm"></div>

  <div class="relative z-10 w-full max-w-4xl mx-4 my-16">
    <div class="bg-black/20 backdrop-blur-md rounded-lg p-6 md:p-8 border border-white/10">
      <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
        <div>
          <h2 class="text-3xl md:text-4xl font-bold text-white mb-2">{title}</h2>
          <p class="text-gray-400">{date} • {location}</p>
        </div>
        <div class="text-right">
          <p class="text-gray-400 text-sm">Length</p>
          <p class="text-white text-xl">{length}</p>
        </div>
      </div>

      <p class="text-gray-300 mb-6">{description}</p>

      {
        (mixcloud || hearthis) && (
          <div class="player-container mb-6">
            {mixcloud && (
              <iframe
                src={`https://www.mixcloud.com/widget/iframe/?hide_cover=1&mini=1&light=1&feed=%2F${mixcloud}%2F`}
                title={title}
                allow="autoplay"
                loading="lazy"
              />
            )}
          </div>
        )
      }

      <button
        class="toggle-tracklist text-white bg-red-600 hover:bg-red-700 px-4 py-2 rounded transition-colors"
        data-target={`tracklist-${id}`}
      >
        Show Tracklist
      </button>

      <div
        id={`tracklist-${id}`}
        class="tracklist mt-4 overflow-hidden transition-all duration-300"
        style="max-height: 0px;"
      >
        <h3 class="text-xl text-white mb-4">Tracklist</h3>
        <ul class="space-y-2">
          {
            tracks.map((track) => (
              <li class="text-gray-300 text-sm">
                <span class="text-red-500">#{String(track.n).padStart(2, "0")}</span> {track.artist}{" "}
                - {track.title}
                {track.label && <span class="text-gray-500"> [{track.label}]</span>}
              </li>
            ))
          }
        </ul>
      </div>
    </div>
  </div>
</article>
